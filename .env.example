# 复制为 .env 后按需修改（.env 已被 git 忽略，不会提交）
MYSQL_PASSWORD=123456
JWT_SECRET=exam-system-docker-jwt-secret-key-please-change-in-production

# AI 大模型（OpenAI 兼容，DeepSeek 示例）
AI_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# RAG 向量 embedding（mock 无需额外 Key；openai 需支持 /embeddings 的接口）
AI_EMBEDDING_ENABLED=true
AI_EMBEDDING_PROVIDER=mock
AI_EMBEDDING_MODEL=text-embedding-3-small
